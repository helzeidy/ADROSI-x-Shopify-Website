{{ 'tabs-section.css' | asset_url | stylesheet_tag }}
<script src="{{ 'tabs-section.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign nav_align_class = ''
  if section.settings.tab_alignment == 'center'
    assign nav_align_class = ' tabs-section__nav--center'
  endif
-%}

<div class="tabs-section color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="tabs-section__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="tabs-section__title {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="tabs-section__wrap" data-tabs>
        <div class="tabs-section__nav{{ nav_align_class }}" role="tablist">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="tabs-section__tab{% if forloop.first %} is-active{% endif %}"
              data-tab-btn="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
              {{ block.shopify_attributes }}
            >
              {{- block.settings.tab_label | default: 'Tab' | escape -}}
            </button>
          {%- endfor -%}
        </div>

        <div class="tabs-section__panels">
          {%- for block in section.blocks -%}
            <div
              class="tabs-section__panel{% if forloop.first %} is-active{% endif %}"
              data-tab-panel="{{ forloop.index0 }}"
              role="tabpanel"
              {% unless forloop.first %}hidden{% endunless %}
            >
              {%- liquid
                assign b = block.settings
                assign has_button = false
                if b.button_label != blank and b.button_link != blank
                  assign has_button = true
                endif
              -%}

              {%- if b.layout == 'image_overlay' -%}
                {%- capture bg_style -%}
                  min-height: {{ b.min_height }}px;
                  {%- if b.image and b.video == blank %} background-image: url('{{ b.image | image_url: width: 2000 }}');{% endif -%}
                {%- endcapture -%}
                <div class="tabs-section__overlay" style="{{ bg_style }}">
                  {%- if b.video != blank -%}
                    {{ b.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                  {%- endif -%}

                  <div class="tabs-section__overlay-tint" style="background: {{ b.overlay_color }}; opacity: {{ b.overlay_opacity | divided_by: 100.0 }};"></div>

                  <div class="tabs-section__overlay-inner v-{{ b.vertical_position }} h-{{ b.horizontal_position }}">
                    <div class="tabs-section__overlay-content" style="color: {{ b.text_color }}; max-width: {{ b.text_max_width }}px;">
                      {%- if b.subheading != blank -%}<span class="tabs-section__subheading">{{ b.subheading | escape }}</span>{%- endif -%}
                      {%- if b.heading != blank -%}<h3 class="tabs-section__heading">{{ b.heading | escape }}</h3>{%- endif -%}
                      {%- if b.text != blank -%}<div class="tabs-section__text">{{ b.text }}</div>{%- endif -%}
                      {%- if has_button -%}
                        <div class="tabs-section__cta">
                          <a href="{{ b.button_link }}" class="btn {{ b.button_style }} {{ b.button_type }}">{{ b.button_label | escape }}</a>
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </div>

              {%- else -%}
                <div class="tabs-section__split{% if b.media_position == 'right' %} tabs-section__split--media-right{% endif %}">
                  <div class="tabs-section__media">
                    {%- if b.video != blank -%}
                      {{ b.video | video_tag: controls: true, loop: b.video_loop, muted: b.video_loop, autoplay: b.video_loop, playsinline: true }}
                    {%- elsif b.image != blank -%}
                      {{ b.image | image_url: width: 1400 | image_tag: widths: '400, 600, 800, 1100, 1400', sizes: '(min-width: 750px) 50vw, 100vw', loading: 'lazy', alt: b.heading | default: b.tab_label | escape }}
                    {%- endif -%}
                  </div>

                  <div class="tabs-section__text-col">
                    {%- if b.subheading != blank -%}<span class="tabs-section__subheading">{{ b.subheading | escape }}</span>{%- endif -%}
                    {%- if b.heading != blank -%}<h3 class="tabs-section__heading">{{ b.heading | escape }}</h3>{%- endif -%}
                    {%- if b.text != blank -%}<div class="tabs-section__text">{{ b.text }}</div>{%- endif -%}
                    {%- if has_button -%}
                      <div class="tabs-section__cta">
                        <a href="{{ b.button_link }}" class="btn {{ b.button_style }} {{ b.button_type }}">{{ b.button_label | escape }}</a>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <div class="tabs-section__inner">{{ 'sections.tabs.no_blocks' | t | default: 'Add tabs to this section.' }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Tabs",
  "tag": "section",
  "class": "section-tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "info": "Optional heading above the tabs."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "heading-medium",
      "options": [
        {"value": "heading-small", "label": "Small"},
        {"value": "heading-medium", "label": "Medium"},
        {"value": "heading-large", "label": "Large"}
      ]
    },
    {
      "type": "select",
      "id": "tab_alignment",
      "label": "Tabs alignment",
      "default": "left",
      "options": [
        {"value": "left", "label": "Left"},
        {"value": "center", "label": "Center"}
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme_1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "default": "Tab"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Layout",
          "default": "media_text",
          "options": [
            {"value": "media_text", "label": "Media + text (side by side)"},
            {"value": "image_overlay", "label": "Full image with text on top"}
          ]
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading (small, above heading)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "If set, the video is used instead of the image."
        },
        {
          "type": "checkbox",
          "id": "video_loop",
          "label": "Autoplay & loop video (muted)",
          "default": false,
          "info": "Side-by-side layout only. Off shows normal video controls."
        },
        {
          "type": "select",
          "id": "media_position",
          "label": "Media position (side by side)",
          "default": "left",
          "options": [
            {"value": "left", "label": "Left"},
            {"value": "right", "label": "Right"}
          ]
        },
        {
          "type": "header",
          "content": "Full image overlay",
          "info": "Applies when Layout is \"Full image with text on top\"."
        },
        {
          "type": "range",
          "id": "min_height",
          "min": 200,
          "max": 900,
          "step": 20,
          "unit": "px",
          "label": "Height",
          "default": 500
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Overlay opacity",
          "default": 30
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "text_max_width",
          "min": 200,
          "max": 1000,
          "step": 20,
          "unit": "px",
          "label": "Text max width",
          "default": 560
        },
        {
          "type": "select",
          "id": "vertical_position",
          "label": "Text vertical position",
          "default": "center",
          "options": [
            {"value": "top", "label": "Top"},
            {"value": "center", "label": "Center"},
            {"value": "bottom", "label": "Bottom"}
          ]
        },
        {
          "type": "select",
          "id": "horizontal_position",
          "label": "Text horizontal position",
          "default": "left",
          "options": [
            {"value": "left", "label": "Left"},
            {"value": "center", "label": "Center"},
            {"value": "right", "label": "Right"}
          ]
        },
        {
          "type": "header",
          "content": "Button (optional)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_type",
          "label": "Button color",
          "default": "btn--primary",
          "options": [
            {"value": "btn--black", "label": "Black"},
            {"value": "btn--white", "label": "White"},
            {"value": "btn--primary", "label": "Primary"},
            {"value": "btn--secondary", "label": "Secondary"}
          ]
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "default": "btn--solid",
          "options": [
            {"value": "btn--solid", "label": "Solid"},
            {"value": "btn--outline", "label": "Outline"}
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabs",
      "blocks": [
        {"type": "tab", "settings": {"tab_label": "Material", "heading": "Suede leather"}},
        {"type": "tab", "settings": {"tab_label": "Construction", "heading": "Blake Rapid construction"}},
        {"type": "tab", "settings": {"tab_label": "Sole", "heading": "Sole"}}
      ]
    }
  ]
}
{% endschema %}
