{%- liquid
  assign text_color = section.settings.color
  assign bg_color = section.settings.bg_color
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign sub_collections = linklists[collection.handle].links
  assign sub_collection_html = ''
  assign sub_collection_counter = 0
  assign sub_collection_limit = 6
  assign card_style = section.settings.card_style | default: 'overlay'
  assign is_minimal = false
  if card_style == 'minimal'
    assign is_minimal = true
  endif
-%}

{%- if linklists[collection.handle].links.size > 0 -%}
  {%- style -%}
    #Subcollections--{{ section.id }} {
      --PT: {{ section.settings.padding_top }}px;
      --PB: {{ section.settings.padding_bottom }}px;
      --subcard-max: {{ section.settings.card_max_width | default: 220 }}px;
      --subcard-gap: {{ section.settings.card_gap | default: 28 }}px;
      --subcard-title-size: {{ section.settings.title_size | default: 14 }}px;

      {%- unless text_color == 'rgba(0,0,0,0)' or text_color == blank -%}
        --text: {{ text_color }};
      {%- endunless -%}

      {%- unless bg_color == 'rgba(0,0,0,0)' or bg_color == blank -%}
        --bg: {{ bg_color }};
      {%- endunless -%}
    }

    {%- if is_minimal -%}
      /* Minimal card style: square image, centered title below, no overlay. */
      .subcollections--minimal .grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--subcard-gap, 28px);
      }
      .subcollections--minimal .grid-item.subcollection__item {
        position: relative;
        height: auto;
        flex: 0 0 auto;
        width: var(--subcard-max, 220px);
        max-width: var(--subcard-max, 220px);
        overflow: visible;
      }
      .subcollections--minimal .subcollection__inner {
        height: auto;
      }
      .subcollections--minimal .subcollection__link {
        position: static;
        display: block;
        padding: 0;
        height: auto;
      }
      .subcollections--minimal .subcollection__image {
        position: relative;
        transform: none;
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 10px;
        overflow: hidden;
        transition: background-color 0.2s ease;
      }
      .subcollections--minimal .subcollection__link:hover .subcollection__image {
        transform: none;
        background-color: rgba(0, 0, 0, 0.06);
      }
      .subcollections--minimal .subcollection__image .image-wrapper {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }
      .subcollections--minimal .subcollection__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .subcollections--minimal .subcollection__text {
        position: static;
        padding: 14px 4px 0;
        text-align: center;
      }
      .subcollections--minimal .subcollection__title {
        margin: 0;
        font-family: var(--FONT-STACK-SUBHEADING, inherit);
        font-weight: var(--FONT-WEIGHT-SUBHEADING, 400);
        font-size: var(--subcard-title-size, 14px);
        letter-spacing: var(--LETTER-SPACING-SUBHEADING, 0.1em);
        text-transform: uppercase;
      }
      @media (max-width: 749px) {
        .subcollections--minimal .grid {
          flex-wrap: nowrap;
          justify-content: flex-start;
          overflow-x: auto;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
        }
        .subcollections--minimal .grid::-webkit-scrollbar {
          display: none;
        }
        .subcollections--minimal .grid-item.subcollection__item {
          width: 160px;
        }
      }
    {%- endif -%}
  {%- endstyle -%}

{%- render 'stylesheet', name: 'subcollections.css', inline: true -%}

  <section
    class="subcollections{% if is_minimal %} subcollections--minimal{% endif %} collection-{{ collection.handle }} section-padding {{ color_scheme }}"
    id="Subcollections--{{ section.id }}"
  >
    {%- if sub_collections.size > 0 -%}
      {%- for sublink in sub_collections -%}
        {%- liquid
          if sublink.type != 'collection_link' or sublink.object.handle == blank
            continue
          endif

          assign sub_collection_handle = sublink.object.handle
          assign sub_collection_handle_separator = sub_collection_handle | append: ',' | prepend: ','
          assign sub_collection = collections[sub_collection_handle]

          if sublink.object.handle contains sub_collection_handle_separator
            continue
          endif
        -%}

        {%- capture sub_collection_html -%}
          {{ sub_collection_html }}

          <div class="grid-item subcollection__item" data-grid-item>
            <div class="subcollection__inner">
              <a class="subcollection__link" href="{{ sub_collection.url }}">
                <div class="subcollection__image">
                  {%- assign image = sub_collection.image -%}

                  {%- if section.settings.select_image == 'product' or image == blank -%}
                    {%- assign image = sub_collection.products.first.featured_media.preview_image -%}
                  {%- endif -%}

                  {%- capture sizes -%}
                    (min-width: 750px) (calc(100vw - 16px) / 3), calc(100vw - 32px)
                  {%- endcapture -%}

                  {%- render 'image' image: image, sizes: sizes, cover: true -%}
                </div>
                {%- unless is_minimal -%}
                  <div class="image-overlay-bottom"></div>
                {%- endunless -%}
                <div class="subcollection__text">
                  <p class="subcollection__title h4">{{ sub_collection.title }}</p>
                  {%- if sub_collection.description != '' and section.settings.subcollection_description -%}
                    <div class="subcollection__description">{{ sub_collection.description }}</div>
                  {%- endif -%}
                </div>
              </a>
            </div>
          </div>
        {%- endcapture -%}

        {%- assign sub_collection_counter = sub_collection_counter | plus: 1 -%}

        {%- if sub_collection_counter >= sub_collection_limit -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if sub_collection_html != '' -%}
        {%- liquid
          assign layout_slider = false
          if section.settings.subcollection_layout == 'slider' and sub_collection_counter > 4
            assign layout_slider = true
          endif

          assign columns_desktop = sub_collection_counter | at_most: 4
          assign columns_medium = 3

          if columns_desktop == 2 or columns_desktop == 4
            assign columns_medium = 2
          endif
        -%}

        {%- capture sub_collection_html -%}
          <div class="grid{% if layout_slider %} grid--slider{% endif %} grid--mobile-slider"{% if layout_slider %} data-grid-slider{% endif %} style="--COLUMNS: {{ columns_desktop }}; --COLUMNS-MEDIUM: {{ columns_medium }};">
            {{ sub_collection_html }}
          </div>
        {%- endcapture -%}

        <div class="grid-outer">
          {%- if layout_slider -%}
            <grid-slider>
              {{ sub_collection_html }}
            </grid-slider>
          {%- else -%}
            {{ sub_collection_html }}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Subcollections",
  "settings": [
    {
      "type": "paragraph",
      "content": "Create a [navigation list](/admin/content/menus) with the same name as this collection and link to other collections. [Learn more](https://broadcast.presidiocreative.com/collections/collection-pages/sub-collections)"
    },
    {
      "type": "select",
      "id": "subcollection_layout",
      "label": "Layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "default": "overlay",
      "options": [
        {"value": "overlay", "label": "Title over image (default)"},
        {"value": "minimal", "label": "Square image, title below"}
      ],
      "info": "Square style: centered title under the image, no dark overlay."
    },
    {
      "type": "range",
      "id": "card_max_width",
      "min": 120,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Card max width",
      "default": 220,
      "visible_if": "{{ section.settings.card_style == 'minimal' }}"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards",
      "default": 28,
      "visible_if": "{{ section.settings.card_style == 'minimal' }}"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 8,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Title text size",
      "default": 14,
      "visible_if": "{{ section.settings.card_style == 'minimal' }}"
    },
    {
      "type": "checkbox",
      "id": "subcollection_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "select",
      "id": "select_image",
      "label": "Select a photo to display",
      "options": [
        {
          "value": "collection",
          "label": "Collection image"
        },
        {
          "value": "product",
          "label": "Product image"
        }
      ]
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Text",
      "default": "#ffffff",
      "alpha": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "alpha": true
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 20
    }
  ]
}
{% endschema %}
