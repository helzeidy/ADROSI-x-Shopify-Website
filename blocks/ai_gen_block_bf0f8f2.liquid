{% doc %}
  @prompt
    Create a collection list section with a slider/carousel layout where the heading, descriptive text, and a call-to-action button are overlaid on top of the collection images. The text and button should be positioned over the collection cards within the slider, with customizable options for heading text, description text, button label and link, text color, overlay opacity, and alignment. The section should support multiple collections displayed as slides.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign slides_desktop = block.settings.slides_desktop
  assign slides_mobile = block.settings.slides_mobile
  assign slide_gap = block.settings.slide_gap
  
  if slides_desktop == 1
    assign slides_per_view = 100
  elsif slides_desktop == 2
    assign slides_per_view = 50
  elsif slides_desktop == 3
    assign slides_per_view = 33.333
  else
    assign slides_per_view = 25
  endif
  
  if slides_mobile == 1
    assign slides_per_view_mobile = 100
  else
    assign slides_per_view_mobile = 50
  endif
%}

{% style %}
  .ai-collection-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-collection-slider__wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ slide_gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }

  .ai-collection-slider__wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-collection-slider__slide-{{ ai_gen_id }} {
    flex: 0 0 calc({{ slides_per_view }}% - ({{ slide_gap }}px * ({{ slides_desktop }} - 1) / {{ slides_desktop }}));
    scroll-snap-align: start;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-collection-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-collection-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collection-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-slider__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-slider__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  .ai-collection-slider__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    align-items: {{ block.settings.horizontal_alignment }};
    padding: {{ block.settings.content_padding }}px;
    text-align: {% if block.settings.horizontal_alignment == 'flex-start' %}left{% elsif block.settings.horizontal_alignment == 'flex-end' %}right{% else %}center{% endif %};
    z-index: 2;
  }

  .ai-collection-slider__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-collection-slider__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.5;
  }

  .ai-collection-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_border_color }};
  }

  .ai-collection-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-collection-slider__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-collection-slider__nav-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-collection-slider__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
    color: {{ block.settings.nav_hover_icon_color }};
  }

  .ai-collection-slider__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-collection-slider__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-collection-slider__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-collection-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-slider__slide-{{ ai_gen_id }} {
      flex: 0 0 calc({{ slides_per_view_mobile }}% - ({{ slide_gap }}px * ({{ slides_mobile }} - 1) / {{ slides_mobile }}));
    }

    .ai-collection-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-collection-slider__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.85 }}px;
    }

    .ai-collection-slider__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }

    .ai-collection-slider__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.6 }}px;
    }
  }
{% endstyle %}

<collection-slider-{{ ai_gen_id }} class="ai-collection-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-slider__wrapper-{{ ai_gen_id }}" data-slider-wrapper>
    {% if block.settings.collections != blank %}
      {% for collection in block.settings.collections %}
        <div class="ai-collection-slider__slide-{{ ai_gen_id }}">
          <div class="ai-collection-slider__image-wrapper-{{ ai_gen_id }}">
            {% if collection.featured_image %}
              <img
                src="{{ collection.featured_image | image_url: width: 1200 }}"
                alt="{{ collection.featured_image.alt | escape }}"
                loading="lazy"
                width="{{ collection.featured_image.width }}"
                height="{{ collection.featured_image.height }}"
                class="ai-collection-slider__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-collection-slider__placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
            <div class="ai-collection-slider__overlay-{{ ai_gen_id }}"></div>
            <div class="ai-collection-slider__content-{{ ai_gen_id }}">
              {% if block.settings.show_heading %}
                <h3 class="ai-collection-slider__heading-{{ ai_gen_id }}">
                  {{ collection.title }}
                </h3>
              {% endif %}
              {% if block.settings.show_description and collection.description != blank %}
                <div class="ai-collection-slider__description-{{ ai_gen_id }}">
                  {{ collection.description | strip_html | truncate: 120 }}
                </div>
              {% endif %}
              {% if block.settings.show_button %}
                <a
                  href="{{ collection.url }}"
                  class="ai-collection-slider__button-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      {% for i in (1..4) %}
        <div class="ai-collection-slider__slide-{{ ai_gen_id }}">
          <div class="ai-collection-slider__image-wrapper-{{ ai_gen_id }}">
            <div class="ai-collection-slider__placeholder-{{ ai_gen_id }}">
              {{ 'collection-1' | placeholder_svg_tag }}
            </div>
            <div class="ai-collection-slider__overlay-{{ ai_gen_id }}"></div>
            <div class="ai-collection-slider__content-{{ ai_gen_id }}">
              {% if block.settings.show_heading %}
                <h3 class="ai-collection-slider__heading-{{ ai_gen_id }}">
                  Collection {{ i }}
                </h3>
              {% endif %}
              {% if block.settings.show_description %}
                <div class="ai-collection-slider__description-{{ ai_gen_id }}">
                  Discover our curated collection
                </div>
              {% endif %}
              {% if block.settings.show_button %}
                <a
                  href="#"
                  class="ai-collection-slider__button-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  {% if block.settings.show_navigation %}
    <div class="ai-collection-slider__nav-{{ ai_gen_id }}">
      <button
        class="ai-collection-slider__nav-button-{{ ai_gen_id }}"
        data-prev-button
        aria-label="Previous slide"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-collection-slider__nav-button-{{ ai_gen_id }}"
        data-next-button
        aria-label="Next slide"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}

  {% if block.settings.show_dots %}
    <div class="ai-collection-slider__dots-{{ ai_gen_id }}" data-dots></div>
  {% endif %}
</collection-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.wrapper = this.querySelector('[data-slider-wrapper]');
        this.slides = this.wrapper.querySelectorAll('.ai-collection-slider__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-prev-button]');
        this.nextButton = this.querySelector('[data-next-button]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.currentIndex = 0;
        this.slidesPerView = {{ slides_desktop }};
      }

      connectedCallback() {
        this.setupDots();
        this.setupEventListeners();
        this.updateButtons();
        this.handleResize();
      }

      setupDots() {
        if (!this.dotsContainer) return;
        
        const totalSlides = this.slides.length;
        const maxIndex = Math.max(0, totalSlides - this.slidesPerView);
        
        for (let i = 0; i <= maxIndex; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-collection-slider__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }

        this.wrapper.addEventListener('scroll', () => {
          this.updateActiveSlide();
        });

        window.addEventListener('resize', () => this.handleResize());
      }

      handleResize() {
        if (window.innerWidth <= 749) {
          this.slidesPerView = {{ slides_mobile }};
        } else {
          this.slidesPerView = {{ slides_desktop }};
        }
        this.updateButtons();
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.goToSlide(this.currentIndex);
        }
      }

      next() {
        const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.goToSlide(this.currentIndex);
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ slide_gap }};
        const scrollPosition = (slideWidth + gap) * index;
        
        this.wrapper.scrollTo({
          left: scrollPosition,
          behavior: 'smooth'
        });

        this.updateButtons();
        this.updateDots();
      }

      updateActiveSlide() {
        const scrollLeft = this.wrapper.scrollLeft;
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ slide_gap }};
        const newIndex = Math.round(scrollLeft / (slideWidth + gap));
        
        if (newIndex !== this.currentIndex) {
          this.currentIndex = newIndex;
          this.updateButtons();
          this.updateDots();
        }
      }

      updateButtons() {
        if (!this.prevButton || !this.nextButton) return;

        const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
        
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }

      updateDots() {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-collection-slider__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('collection-slider-{{ ai_gen_id }}', CollectionSlider{{ ai_gen_id }});
  })();
</script>

