<!-- /snippets/cart-bar.liquid -->

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign blocks_form = section.blocks | where: 'type', 'form'
  assign button_add = false

  if product.has_only_default_variant
    assign button_add = true
  endif

  if settings.currency_code_enable
    assign current_variant_price = current_variant.price | money_with_currency
    assign current_variant_compare_at_price = current_variant.compare_at_price | money_with_currency
  else
    assign current_variant_price = current_variant.price | money
    assign current_variant_compare_at_price = current_variant.compare_at_price | money
  endif

  assign any_variant_available = false
  for option in product.options_with_values
    for option_value in option.values
      if option_value.available
        assign any_variant_available = true
        break
      endif
    endfor
  endfor

  assign bar_button_type = section.settings.cart_bar_button_type | default: 'btn--primary'
  assign bar_button_style = section.settings.cart_bar_button_style | default: 'btn--solid'
  assign bar_label = section.settings.cart_bar_label
  assign bar_variant_action = section.settings.cart_bar_variant_action | default: 'add'
  assign bar_show_image = section.settings.cart_bar_show_image
  assign bar_image = current_variant.featured_media.preview_image | default: product.featured_image

  comment
    Decide whether the cart bar button adds to cart or scrolls to the options.
    Default-variant products always add; products with options follow the setting.
  endcomment
  assign bar_is_add = true
  unless button_add
    if bar_variant_action == 'scroll'
      assign bar_is_add = false
    endif
  endunless
-%}

{%- render 'stylesheet', name: 'cart-bar.css' -%}

{%- style -%}
  :root {
    --cart-bar-height: 80px;
  }
{%- endstyle -%}

<script src="{{ 'cart-bar.js' | asset_url }}" defer="defer"></script>

<cart-bar id="CartBar-{{ section.id }}" class="cart-bar">
  <div
    class="cart-bar__form__wrapper form__wrapper{% if button_add and current_variant.available != true %} variant--soldout{% endif %}{% if settings.show_newsletter %} show-product-notification{% endif %}{% unless any_variant_available %} all-variants--soldout{% endunless %}"
    data-form-wrapper
  >
    {%- if bar_show_image and bar_image -%}
      <div class="cart-bar__image">
        {{ bar_image | image_url: width: 120 | image_tag: widths: '60, 120', sizes: '60px', loading: 'lazy', alt: product.title | escape }}
      </div>
    {%- endif -%}

    <div class="cart-bar__info">
      <h4 class="cart-bar__product__title">{{ product.title | strip_html }}</h4>

      <div class="body-small cart-bar__product__price product__price">
        <span
          data-product-price
          {% if current_variant.compare_at_price > current_variant.price %}
            class="product__price--sale"
          {% endif %}
        >
          {%- if current_variant.price == 0 -%}
            {{ 'general.money.free' | t }}
          {%- else -%}
            {{ current_variant_price }}
          {%- endif -%}
        </span>

        {% if product.compare_at_price_max > product.price %}
          <span class="visually-hidden" data-compare-text>{{ 'products.product.regular_price' | t }}</span>
          <s class="product__price--strike">
            {% if current_variant.compare_at_price > current_variant.price %}
              {{ current_variant_compare_at_price }}
            {% endif %}
          </s>
        {% endif %}
      </div>
    </div>

    <div class="cart-bar__form">
      <div class="cart-bar__submit product__submit product__submit--spb">
        <button
          type="button"
          class="btn {{ bar_button_type }} {{ bar_button_style }} product__submit__add{% unless bar_is_add %} product__submit__add--default{% endunless %}"
          {% if bar_is_add %}
            data-cart-bar-add-to-cart
          {% elsif any_variant_available %}
            data-cart-bar-scroll
          {% endif %}
          {% if any_variant_available == false or bar_is_add and current_variant.available != true %}
            disabled="disabled"
          {% endif %}
        >
          <span
            class="btn__text"
            {% if bar_is_add %}
              data-add-to-cart-text
            {% endif %}
          >
            {%- if bar_label != blank -%}
              {{ bar_label }}
            {%- elsif bar_is_add -%}
              {%- assign preorder_check = false -%}

              {%- if product.tags contains '_preorder' or product.metafields.theme.preorder.value -%}
                {%- assign preorder_check = true -%}
              {%- endif -%}

              {%- if current_variant.available and preorder_check -%}
                {{ 'products.product.pre_order' | t }}
              {%- elsif current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            {%- elsif any_variant_available -%}
              {{ 'products.product.configure' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </span>

          <span class="btn__loader">
            <svg height="18" width="18" class="svg-loader">
              <circle r="7" cx="9" cy="9" />
              <circle stroke-dasharray="87.96459430051421 87.96459430051421" r="7" cx="9" cy="9" />
            </svg>
          </span>

          <span class="btn__added">&nbsp;</span>

          {%- unless bar_is_add or any_variant_available == false -%}
            {%- render 'icon-nav-arrow-up' -%}
          {%- endunless -%}
        </button>

        {%- if settings.show_newsletter -%}
          {%- assign newsletter_text = 'general.newsletter_form.newsletter_product_availability' | t -%}
          {%- assign newsletter_button_text = 'products.product.sold_out'
            | t
            | append: ' - '
            | append: newsletter_text
          -%}

          <button
            type="button"
            class="btn btn--primary btn--outline product__submit__add product__submit__add--default product__cart-bar-notification-button"
            data-notification-popup-button
          >
            <span class="btn__text">{{ newsletter_button_text }}</span>
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
</cart-bar>
